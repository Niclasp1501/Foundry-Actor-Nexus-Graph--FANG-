<div class="fang-app-container">
    <!-- Sidebar / Toolbar -->
    <aside class="sidebar glass-panel">
        <header class="sidebar-header">
            <h1>{{localize "FANG.Name"}}</h1>
            <p>{{localize "FANG.Subtitle"}}</p>
        </header>

        <nav class="tabs-nav" role="tablist" aria-label="{{localize 'FANG.Name'}}">
            <button type="button" class="tab-btn active" role="tab" aria-selected="true" data-tab="editor">
                <i class="fas fa-hammer" aria-hidden="true"></i> {{localize "FANG.UI.TabEditor"}}
            </button>
            <button type="button" class="tab-btn gm-only" role="tab" aria-selected="false" data-tab="view">
                <i class="fas fa-eye" aria-hidden="true"></i> {{localize "FANG.UI.TabView"}}
            </button>
            <button type="button" class="tab-btn gm-only" role="tab" aria-selected="false" data-tab="advanced"
                aria-label="{{localize 'FANG.UI.TabAdvanced'}}">
                <i class="fas fa-cogs" aria-hidden="true"></i>
            </button>
        </nav>

        <div class="tabs-container">
            <!-- EDITOR TAB -->
            <section class="tab-content active" data-tab="editor">
                <!-- Edit Lock Banner -->
                <div id="fang-lock-banner" class="lock-banner no-editor">
                    <div class="lock-info">
                        <i class="fas fa-lock-open" aria-hidden="true"></i>
                        <span id="lock-text">{{localize "FANG.UI.NoEditor"}}</span>
                    </div>
                    <button id="btnToggleLock" class="fang-lock-btn">
                        <i class="fas fa-pencil-alt" aria-hidden="true"></i>
                        <span id="lock-btn-text">{{localize "FANG.UI.EditMode"}}</span>
                    </button>
                    <button id="btnForceRelease" class="fang-lock-btn gm-only hidden"
                        title="{{localize 'FANG.UI.ForceRelease'}}">
                        <i class="fas fa-unlock-alt" aria-hidden="true"></i>
                    </button>
                </div>

                <div class="control-group">
                    <h3>{{localize "FANG.UI.CreateConnection"}}</h3>
                    <div class="input-stack">
                        <select id="sourceSelect">
                            <option value="" disabled selected>{{localize "FANG.UI.SelectSource"}}</option>
                        </select>
                        <select id="targetSelect">
                            <option value="" disabled selected>{{localize "FANG.UI.SelectTarget"}}</option>
                        </select>
                        <input type="text" id="linkLabel" placeholder="{{localize 'FANG.UI.LabelPlaceholder'}}">
                        <div class="fang-form-row compact">
                            <label for="linkDirectional" class="fang-form-label--small">
                                {{localize "FANG.UI.Directional"}}
                            </label>
                            <input type="checkbox" id="linkDirectional" class="fang-inline-checkbox">
                        </div>
                        <button id="btnAddLink" class="btn secondary-btn">{{localize "FANG.UI.Connect"}}</button>
                        <button id="btnAddPlaceholder" class="btn action-btn">{{localize "FANG.UI.AddPlaceholder"}}</button>
                    </div>
                </div>

                <div class="control-group">
                    <h3>{{localize "FANG.UI.ManageElements"}}</h3>
                    <div class="input-stack">
                        <select id="deleteSelect">
                            <option value="" disabled selected>{{localize "FANG.UI.SelectElement"}}</option>
                        </select>
                        <button id="btnDeleteElement" class="btn danger-btn btn--block">
                            <i class="fas fa-trash" aria-hidden="true"></i> {{localize "FANG.UI.Delete"}}
                        </button>

                        <div id="nodeEditGroup" class="input-stack fang-edit-group hidden">
                            <h3>{{localize "FANG.UI.EditNodeHeader"}}</h3>
                            <div class="fang-button-row-tight">
                                <button id="btnToggleCenter" class="btn action-btn btn--block"
                                    title="{{localize 'FANG.UI.ToggleCenterHint'}}">
                                    <i class="fas fa-bullseye" aria-hidden="true"></i> {{localize "FANG.UI.ToggleCenter"}}
                                </button>
                            </div>
                        </div>

                        <!-- Link Edit Group (Hidden by default) -->
                        <div id="linkEditGroup" class="input-stack fang-edit-group hidden">
                            <h3>{{localize "FANG.UI.EditLinkHeader"}}</h3>
                            <p class="fang-help-text fang-help-text--tight">
                                {{localize "FANG.UI.EditLinkHint"}}
                            </p>

                            <input type="text" id="editLinkLabel" placeholder="{{localize 'FANG.UI.LabelPlaceholder'}}">

                            <div class="fang-form-row">
                                <label for="editLinkDirectional" class="fang-form-label--small">
                                    {{localize "FANG.UI.Directional"}}
                                </label>
                                <input type="checkbox" id="editLinkDirectional" class="fang-inline-checkbox">
                            </div>

                            <button id="btnUpdateLink" class="btn action-btn btn--block">
                                <i class="fas fa-save" aria-hidden="true"></i> {{localize "FANG.UI.UpdateLink"}}
                            </button>
                        </div>
                    </div>
                </div>
            </section>

            <!-- VIEW / PRESENTATION TAB -->
            <section class="tab-content gm-only" data-tab="view">
                <div class="control-group">
                    <h3>{{localize "FANG.UI.Presentation"}}</h3>
                    <div class="input-stack">
                        <!-- Player Group -->
                        <div class="button-group-nest">
                            <h4>{{localize "FANG.UI.GroupPlayers"}}</h4>
                            <button id="btnShareGraph" class="btn action-btn"
                                title="{{localize 'FANG.UI.ShowPlayersHint'}}">
                                <i class="fas fa-eye" aria-hidden="true"></i> {{localize "FANG.UI.ShowPlayers"}}
                            </button>
                            <button id="btnCloseGraphRemote" class="btn action-btn"
                                title="{{localize 'FANG.UI.ClosePlayersHint'}}">
                                <i class="fas fa-times-circle" aria-hidden="true"></i> {{localize "FANG.UI.ClosePlayers"}}
                            </button>
                        </div>

                        <!-- Monitor Group -->
                        <div id="monitor-controls-group"
                            class="button-group-nest {{#unless showMonitorControls}}hidden{{/unless}}">
                            <h4>{{localize "FANG.UI.GroupMonitor"}}</h4>
                            <button id="btnShareGraphMonitor" class="btn action-btn"
                                title="{{localize 'FANG.UI.ShowMonitorHint'}}">
                                <i class="fas fa-tv" aria-hidden="true"></i> {{localize "FANG.UI.ShowMonitor"}}
                            </button>
                            <button id="btnCloseGraphMonitor" class="btn action-btn"
                                title="{{localize 'FANG.UI.CloseMonitorHint'}}">
                                <i class="fas fa-desktop" aria-hidden="true"></i> {{localize "FANG.UI.CloseMonitor"}}
                            </button>
                        </div>

                        <button id="btnCenterGraph" class="btn action-btn btn--accent"
                            title="{{localize 'FANG.UI.CenterGraphHint'}}">
                            <i class="fas fa-expand-arrows-alt" aria-hidden="true"></i> {{localize "FANG.UI.CenterGraph"}}
                        </button>

                        <button id="btnToggleSearchOverlay" class="btn action-btn"
                            title="{{localize 'FANG.UI.SearchToggleHint'}}">
                            <i class="fas fa-search" aria-hidden="true"></i> {{localize "FANG.UI.SearchToggle"}}
                        </button>
                     </div>
                 </div>

                <div class="control-group">
                    <h3>{{localize "FANG.Physics.Title"}}</h3>
                    <div class="input-stack">
                        <div class="fang-form-row">
                            <label for="cbEnableCosmicWind" class="fang-form-label">
                                {{localize "FANG.Physics.CosmicWind"}}
                            </label>
                            <input type="checkbox" id="cbEnableCosmicWind" class="fang-inline-checkbox">
                        </div>
                        <div class="fang-slider-group">
                            <div class="fang-slider-meta">
                                <span>{{localize "FANG.Physics.Strength"}}</span>
                                <span id="wind-strength-val">4</span>
                            </div>
                            <input type="range" id="rngCosmicWindStrength" class="fang-slider"
                                min="0.1" max="10" step="0.1" value="4">
                        </div>
                        <p class="fang-help-text">{{localize "FANG.Physics.Hint"}}</p>
                    </div>
                </div>

                <div class="control-group">
                    <h3>{{localize "FANG.UI.SpectatorMode"}}</h3>
                    <div class="input-stack">
                        <div class="fang-form-row">
                            <label for="cbSyncCamera" class="fang-form-label">
                                {{localize "FANG.UI.SyncCamera"}}
                            </label>
                            <input type="checkbox" id="cbSyncCamera" class="fang-inline-checkbox">
                        </div>
                        <p class="fang-help-text fang-help-text--tight">
                            {{localize "FANG.UI.SyncCameraHint"}}
                        </p>
                    </div>
                </div>

                <div class="control-group">
                    <h3>{{localize "FANG.UI.AdvancedFeatures"}}</h3>
                    <div class="input-stack">
                        <div class="fang-form-row">
                            <label for="cbAllowPlayerEdit" class="fang-form-label">
                                {{localize "FANG.Settings.AllowPlayerEditing.Name"}}
                            </label>
                            <input type="checkbox" id="cbAllowPlayerEdit" class="fang-inline-checkbox">
                        </div>
                        <p class="fang-help-text fang-help-text--tight">
                            {{localize "FANG.Settings.AllowPlayerEditing.Hint"}}
                        </p>
                    </div>
                </div>
            </section>

            <!-- ADVANCED TAB -->
            <section class="tab-content gm-only" data-tab="advanced">
                <div class="control-group">
                    <h3>{{localize "FANG.UI.ManageFactions"}}</h3>
                    <div class="input-stack">
                        <button id="btnManageFactions" class="btn action-btn btn--block"
                            title="{{localize 'FANG.UI.ManageFactionsHint'}}">
                            <i class="fas fa-users-cog" aria-hidden="true"></i> {{localize "FANG.UI.ManageFactions"}}
                        </button>
                    </div>
                </div>

                <div class="control-group">
                    <h3>{{localize "FANG.ContextMenu.Identity"}}</h3>
                    <div class="input-stack">
                        <div class="fang-form-row">
                            <label for="cbDefaultHidden" class="fang-form-label">
                                {{localize "FANG.Settings.DefaultHidden.Name"}}
                            </label>
                            <input type="checkbox" id="cbDefaultHidden" class="fang-inline-checkbox">
                        </div>
                        <p class="fang-help-text fang-help-text--tight">
                            {{localize "FANG.Settings.DefaultHidden.Hint"}}
                        </p>
                    </div>
                </div>

                <div class="control-group">
                    <h3>{{localize "FANG.UI.Background.Title"}}</h3>
                    <div class="input-stack">
                        <button id="btnOpenBackgroundConfig" class="btn action-btn btn--accent btn--block"
                            title="{{localize 'FANG.UI.Background.BackgroundConfigTitle'}}">
                            <i class="fas fa-palette" aria-hidden="true"></i>
                            {{localize "FANG.UI.Background.BackgroundConfigTitle"}}
                        </button>
                        <p class="section-hint fang-section-hint">
                            {{localize "FANG.UI.Background.Hint"}}
                        </p>
                    </div>
                </div>

                <div class="control-group actions-group">
                    <h3>{{localize "FANG.UI.Export"}} / {{localize "FANG.UI.Import"}}</h3>
                    <div class="button-row">
                        <button id="btnExportGraph" class="btn action-btn">
                            <i class="fas fa-download" aria-hidden="true"></i> {{localize "FANG.UI.ExportBtn"}}
                        </button>
                        <label for="importFile" class="btn action-btn file-label">
                            <i class="fas fa-file-import" aria-hidden="true"></i> {{localize "FANG.UI.ImportBtn"}}
                        </label>
                        <input type="file" id="importFile" class="fang-visually-hidden" accept=".json">
                    </div>
                </div>
            </section>
        </div>
    </aside>

    <!-- Main Canvas Area -->
    <main class="canvas-container">
        <div id="fang-bg-layer"></div>
        <div id="fang-search-floating" class="fang-search-floating hidden">
            <div class="fang-search-row">
                <i class="fas fa-search" aria-hidden="true"></i>
                <input type="text" id="fangSearchInput" placeholder="{{localize 'FANG.UI.SearchPlaceholder'}}">
                <label class="fang-search-isolate-wrap" for="fangSearchIsolate" title="{{localize 'FANG.UI.SearchOnlyMatches'}}">
                    <input type="checkbox" id="fangSearchIsolate">
                    <span>{{localize "FANG.UI.SearchOnlyMatches"}}</span>
                </label>
                <button id="fangSearchClear" class="btn action-btn" title="{{localize 'FANG.UI.SearchCloseHint'}}">
                    <i class="fas fa-times" aria-hidden="true"></i>
                </button>
            </div>
        </div>
        <div id="fang-canvas-lock-indicator" class="canvas-lock-indicator hidden">
            <i class="fas fa-user-edit" aria-hidden="true"></i>
            <span id="canvas-lock-text"></span>
        </div>
        <canvas id="graphCanvas"></canvas>

        <!-- Hover Information Tooltip -->
        <div id="fang-tooltip" class="fang-tooltip hidden"></div>

        <!-- Spectator Mode Activity Indicator -->
        <div id="spectator-active-indicator" class="spectator-active-indicator">
            <i class="fas fa-video" aria-hidden="true"></i> {{localize "FANG.UI.SpectatorActive"}}
        </div>

        <!-- Right-Click Radial Context Menu -->
        <div id="fang-context-menu" class="fang-context-menu hidden">
            <ul>
                <li id="ctxEditRole" class="ctx-item">
                    <i class="fas fa-theater-masks" aria-hidden="true"></i> {{localize "FANG.ContextMenu.EditRole"}}
                </li>
                <li id="ctxEditLore" class="ctx-item">
                    <i class="fas fa-book-open" aria-hidden="true"></i> {{localize "FANG.ContextMenu.EditLore"}}
                </li>
                <li id="ctxOpenJournal" class="ctx-item gm-only">
                    <i class="fas fa-book" aria-hidden="true"></i> {{localize "FANG.ContextMenu.OpenJournal"}}
                </li>
                <li id="ctxOpenQuest" class="ctx-item">
                    <i class="fas fa-scroll" aria-hidden="true"></i> {{localize "FANG.ContextMenu.OpenQuest"}}
                </li>
                <li id="ctxSpotlight" class="ctx-item gm-only">
                    <i class="fas fa-compass" aria-hidden="true"></i> {{localize "FANG.ContextMenu.Spotlight"}}
                </li>
                <li id="ctxIdentity" class="ctx-item">
                    <i class="fas fa-user-secret" aria-hidden="true"></i> {{localize "FANG.ContextMenu.Identity"}}
                </li>
                <li id="ctxReplacePlaceholder" class="ctx-item gm-only">
                    <i class="fas fa-random" aria-hidden="true"></i> {{localize "FANG.ContextMenu.ReplacePlaceholder"}}
                </li>
                <li id="ctxCondition" class="ctx-item">
                    <i class="fas fa-tag" aria-hidden="true"></i> {{localize "FANG.ContextMenu.Condition"}}
                </li>
                <li id="ctxDeleteNode" class="ctx-item danger">
                    <i class="fas fa-trash" aria-hidden="true"></i> {{localize "FANG.ContextMenu.DeleteNode"}}
                </li>
            </ul>
        </div>

        <!-- Edge Right-Click Radial Context Menu -->
        <div id="fang-edge-context-menu" class="fang-context-menu hidden">
            <ul>
                <li id="ctxEditConnection" class="ctx-item">
                    <i class="fas fa-edit" aria-hidden="true"></i> {{localize "FANG.ContextMenu.EditConnection"}}
                </li>
                <li id="ctxEdgeSpotlight" class="ctx-item gm-only">
                    <i class="fas fa-compass" aria-hidden="true"></i> {{localize "FANG.ContextMenu.Spotlight"}}
                </li>
                <li id="ctxDeleteConnection" class="ctx-item danger">
                    <i class="fas fa-unlink" aria-hidden="true"></i> {{localize "FANG.ContextMenu.DeleteConnection"}}
                </li>
            </ul>
        </div>

        <!-- Narrative Spotlight Overlay -->
        <div id="fang-narrative-overlay" class="fang-narrative-overlay hidden">
            <div class="narrative-card">
                <div class="narrative-left-side">
                    <div class="narrative-portrait-container hidden">
                        <img id="narrative-portrait" src="">
                    </div>
                    <div id="narrative-quests-container" class="hidden">
                        <h4 class="narrative-quests-header"><i class="fas fa-scroll" aria-hidden="true"></i> {{localize
                            "FANG.UI.Quests"}}</h4>
                        <ul id="narrative-quests-list"></ul>
                    </div>
                </div>
                <div class="narrative-content">
                    <h2 id="narrative-title"></h2>
                    <div id="narrative-subtitle"></div>
                    <div id="narrative-text"></div>
                </div>
                <div class="narrative-close">
                    <i class="fas fa-times" aria-hidden="true"></i>
                </div>
            </div>
        </div>

        <!-- Quest Spotlight Overlay -->
        <div id="fang-quest-spotlight-overlay" class="fang-narrative-overlay hidden">
            <div class="narrative-card quest-spotlight-card">
                <div class="narrative-content">
                    <h2 id="quest-spotlight-title"></h2>
                    <div id="quest-spotlight-text"></div>
                </div>
                <div class="narrative-close">
                    <i class="fas fa-times" aria-hidden="true"></i>
                </div>
            </div>
        </div>

        <!-- Edge Narrative Spotlight Overlay -->
        <div id="fang-edge-spotlight-overlay" class="fang-narrative-overlay hidden">
            <div class="narrative-card edge-spotlight-card">
                <div class="narrative-portrait-container edge-source-portrait">
                    <img id="edge-source-portrait" src="">
                </div>
                <div class="narrative-content edge-content">
                    <h2 id="edge-narrative-title"></h2>
                    <div id="edge-narrative-text"></div>
                </div>
                <div class="edge-directional-indicator hidden">
                    <i class="fas fa-arrow-right" aria-hidden="true"></i>
                </div>
                <div class="narrative-portrait-container edge-target-portrait">
                    <img id="edge-target-portrait" src="">
                </div>
                <div class="narrative-close">
                    <i class="fas fa-times" aria-hidden="true"></i>
                </div>
            </div>
        </div>
        <!-- Quest Picker Panel (In-Canvas, shown when a node has multiple quests) -->
        <div id="fang-quest-picker" class="fang-quest-picker hidden">
            <div id="fang-quest-picker-header" class="fang-quest-picker-header">
                <i class="fas fa-scroll" aria-hidden="true"></i>
                <span id="fang-quest-picker-title"></span>
            </div>
            <ul id="fang-quest-picker-list" class="fang-quest-picker-list"></ul>
        </div>
    </main>
</div>
